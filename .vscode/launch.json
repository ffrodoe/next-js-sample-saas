{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Docker: Attach to Next.js",
            "type": "node",
            "request": "attach",
            "port": 9230,
            "address": "localhost",
            "localRoot": "${workspaceFolder}",
            "remoteRoot": "/app",
            "sourceMaps": true,
            "smartStep": true,
            "sourceMapPathOverrides": {
                "webpack://_N_E/*": "${workspaceFolder}/*",
                "webpack:///./*": "${workspaceFolder}/*",
                "webpack:///*": "${workspaceFolder}/*"
            },
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ]
}